{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "EngineConfig": {
      "title": "Engine Configuration",
      "description": "User saved engine configurations for the XRD Convolutional Engine",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "configData": { "type": "string" }
      },
      "required": ["userId", "name", "configData", "createdAt", "updatedAt"]
    },
    "BraggHistoryItem": {
      "title": "Bragg History Item",
      "description": "Stored Bragg analysis history item for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string" },
        "sampleId": { "type": "string" },
        "wavelength": { "type": "number" },
        "rawPeaks": { "type": "string" },
        "rawHKL": { "type": "string" },
        "resultsJson": { "type": "string" }
      },
      "required": ["id", "userId", "timestamp", "wavelength", "rawPeaks", "rawHKL", "resultsJson"]
    },
    "CustomMaterial": {
      "title": "Custom Material Spec",
      "description": "User created or premium synced material with fully detailed XRD peak spectrum, mechanical parameters, and chemical statistics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "formula": { "type": "string" },
        "pattern": { "type": "string" },
        "description": { "type": "string" },
        "crystalSystem": { "type": "string" },
        "spaceGroup": { "type": "string" },
        "density": { "type": "number" },
        "molecularWeight": { "type": "number" },
        "elasticModulus": { "type": "number" }
      },
      "required": ["id", "userId", "name", "formula", "pattern"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile information"
    },
    "/engineConfigs/{configId}": {
      "schema": { "$ref": "#/entities/EngineConfig" },
      "description": "User saved engine configurations"
    },
    "/braggHistory/{historyId}": {
      "schema": { "$ref": "#/entities/BraggHistoryItem" },
      "description": "User saved Bragg analysis history"
    },
    "/customMaterials/{materialId}": {
      "schema": { "$ref": "#/entities/CustomMaterial" },
      "description": "Cloud synchronized custom and premium acquired materials"
    }
  }
}
